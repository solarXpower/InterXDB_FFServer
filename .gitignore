# Python cache
__pycache__/
*.pyc
*.pyo

# PyInstaller build artifacts (large — not needed in repo)
build/
dist/
*.spec.bak

# Runtime files (generated on first run)
interxdb.db
interxdb_config.json
person_debug.hex
*.log

# Debug logs
*debuginfo.log

# Large SDK source (binary DLLs — keep only headers and source code)
TC_B_SDK_V64_20250611/**/*.dll
TC_B_SDK_V64_20250611/**/*.lib
TC_B_SDK_V64_20250611/**/*.exe
TC_B_SDK_V64_20250611/**/*.pdb
TC_B_SDK_V64_20250611/**/*.suo
TC_B_SDK_V64_20250611/**/*.cache
TC_B_SDK_V64_20250611/**/obj/
TC_B_SDK_V64_20250611/**/.vs/
TC_B_SDK_V64_20250611/**/.DS_Store

# Installer output
installer/

# PDFs and other large docs (optional — remove lines below to include them)
*.pdf
